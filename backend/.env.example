# Example .env for Dokkhota backend
# Replace placeholder values with real secrets before running in production.
# This file is for development only; do NOT commit real secrets to Git.

# MongoDB Atlas connection string (SRV). Example:
# MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/dokkhota?retryWrites=true&w=majority
MONGO_URI=

# Local fallback MongoDB (used when MONGO_URI is not set or DNS SRV fails)
MONGO_LOCAL_URI=mongodb://127.0.0.1:27017/dokkhota

# Application port
PORT=5000

# JWT secrets for signing tokens
JWT_SECRET=change_me_to_a_secure_random_value
JWT_REFRESH_SECRET=change_me_to_a_secure_random_value

# Frontend origin used for CORS and email links
CLIENT_URL=http://localhost:5173

# Cloudinary credentials for media uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gmail SMTP (use an App Password if using 2FA)
EMAIL_USER=
EMAIL_PASS=

# Set to true to skip real email delivery and log a preview instead
DISABLE_EMAIL=true

# App-specific defaults
STARTER_CREDITS=10
BCRYPT_SALT_ROUNDS=12
